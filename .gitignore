###############################################################################
# Spora .gitignore
###############################################################################

# ── Secrets & user-generated config ─────────────────────────────────────────
# config.php is created by install.php and may contain the DB password.
# It must never be committed. Use config.php.example as the reference template.
config.php

# Dotenv (used by Docker / VPS users instead of config.php)
.env
.env.*
!.env.example
!.env.local.example

# ── Encryption key ───────────────────────────────────────────────────────────
# The key is deliberately stored outside the project by install.php.
# If it ends up inside storage/ as a last resort, make sure it stays out of git.
storage/secret.key

# ── Database ─────────────────────────────────────────────────────────────────
storage/database.sqlite
storage/database-backup.sqlite
storage/database.sqlite-shm
storage/database.sqlite-wal
storage/database.sqlite-journal

# Schema installer stamp — regenerated on every migration run, not source
storage/.schema_stamp

# Keep the empty storage/ directory in the repo
!storage/.gitkeep

# ── Logs ─────────────────────────────────────────────────────────────────────
storage/*.log
*.log

# ── Locks ─────────────────────────────────────────────────────────────────────
storage/*.lock

# ── Composer ─────────────────────────────────────────────────────────────────
/vendor/

# ── Docker ───────────────────────────────────────────────────────────────────
# Runtime env (contains secrets) and persistent storage
docker/.env.local
docker/storage/

# ── Frontend (Vue / Vite) ────────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.vite/
# Vitest coverage output (lcov.info + HTML report); produced by `npm run test:coverage`
frontend/coverage/

# Vite build output (produced by `make dev` / `composer frontend:build`)
public/dist/

# ── PHP tooling ──────────────────────────────────────────────────────────────
.php-cs-fixer.cache
.phpunit.cache/

# ── Claude Code ───────────────────────────────────────────────────────────────
.claude/

# ─VS Code ───────────────────────────────────────────────────────────────────
.vscode/

# Codex
.codex/

# ── OS artefacts ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editor / IDE ─────────────────────────────────────────────────────────────
.idea/
*.swp
*.swo

# ── Misc artefacts ───────────────────────────────────────────────────────────
# Leftover SQLite in-memory filename that can appear at the project root
:memory:

/coverage
/node_modules
