# Spora environment configuration
#
# Copy this file to .env and fill in the values for your local setup.
# .env takes priority over config.php. Docker/VPS users can skip config.php
# entirely and rely on these env vars (or pass them directly as OS env vars).
#
# Run `make setup` to generate .env automatically with a fresh secret key.

# ── Application ───────────────────────────────────────────────────────────────

# development | production
SPORA_APP_ENV=development

# Allow new users to register via POST /api/v1/auth/register
# Set to false once you have created your account.
SPORA_ALLOW_REGISTRATION=true

# ── Encryption ────────────────────────────────────────────────────────────────

# Base64-encoded 32-byte secret key used to encrypt tool credentials at rest.
# Generate with: php -r "echo base64_encode(random_bytes(32));"
# Never commit this value. Losing it means losing access to encrypted settings.
SPORA_SECRET_KEY=

# Alternative: path to a key file instead of an inline value.
# SPORA_KEY_PATH=/home/user/.spora/secret.key

# ── Database ──────────────────────────────────────────────────────────────────

# sqlite (default, zero-config) | mysql
# SPORA_DB_DRIVER=sqlite
# SQLite path is set in config.php (defaults to storage/database.sqlite).

# MySQL / MariaDB — only needed when SPORA_DB_DRIVER=mysql
# SPORA_DB_HOST=127.0.0.1
# SPORA_DB_PORT=3306
# SPORA_DB_NAME=spora
# SPORA_DB_USER=spora
# SPORA_DB_PASSWORD=

# ── Worker ─────────────────────────────────────────────────────────────────────

# Controls how new tasks are created by Orchestrator::start():
#   sync  — HTTP request blocks until agent completes (default, dev only)
#   cron  — Task starts as QUEUED, drained by system cron every minute
#   worker — Task starts as QUEUED, drained by a persistent daemon
#
# Only use sync for local development. Use cron or worker for any deployment.
SPORA_WORKER_MODE=sync

# Minutes after which a RUNNING task is considered orphaned (0 = disabled).
# Set generously — at least 5 minutes — to avoid false positives on slow LLM providers.
# Only applies in cron and worker modes (stale reaper runs at startup in both).
SPORA_WORKER_STALE_MINUTES=60

# ── Mercure (Real-time SSE) ───────────────────────────────────────────────────

# Mercure hub URL for real-time task status updates via Server-Sent Events.
# Omit entirely to disable SSE (tasks still work, but the UI won't auto-refresh).
# Example: http://localhost:3000/.well-known/mercure
# SPORA_MERCURE_URL=

# HS256 shared secret for the Mercure publisher.
# Generate with: php -r "echo bin2hex(random_bytes(32));"
# SPORA_MERCURE_JWT_KEY=

# ── Logging ────────────────────────────────────────────────────────────────────

# debug | info | warning | error
# WARNING is the default. Use debug locally to see all tool dispatch events.
# Do NOT use debug in production — tool arguments (potentially PII) are logged.
SPORA_LOG_LEVEL=warning

# Log file path. Defaults to storage/spora.log.
# SPORA_LOG_PATH=/var/log/spora.log