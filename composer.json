{
    "name": "spora/spora",
    "description": "The WordPress of AI Agents — a portable, zero-configuration agent orchestration platform.",
    "type": "project",
    "license": "MIT",
    "version": "0.1.0",
    "require": {
        "php": "^8.4",
        "chriskonnertz/string-calc": "^2.0",
        "delight-im/auth": "^9.0",
        "dragonmantank/cron-expression": "^3.6",
        "illuminate/database": "^13.0",
        "league/html-to-markdown": "^5.1",
        "monolog/monolog": "^3.10",
        "nikic/fast-route": "^1.3",
        "php-di/php-di": "^7.1",
        "psr/log": "^3.0",
        "symfony/console": "^8.0",
        "symfony/http-client": "^8.0",
        "symfony/http-foundation": "^8.0",
        "symfony/mailer": "^8.0",
        "symfony/yaml": "^8.0",
        "vlucas/phpdotenv": "^5.6",
        "webklex/php-imap": "^6.2"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.94",
        "larastan/larastan": "^3.9",
        "mockery/mockery": "^1.6",
        "pestphp/pest": "^4.0",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "Spora\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        },
        "exclude-from-classmap": [
            "tests/Fixtures/plugins_with_migrations/",
            "tests/Fixtures/plugins_with_manifest/",
            "tests/Fixtures/plugins_bad_migrations/",
            "tests/Fixtures/plugins_with_custom_file/",
            "tests/Feature/RouterTest.php"
        ]
    },
    "scripts": {
        "setup": [
            "@php bin/reset-db",
            "@php bin/spora spora:install",
            "@php bin/spora db:seed"
        ],
        "reset": "@php bin/reset-db",
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "bin/dev"
        ],
        "install:db": "@php bin/spora spora:install",
        "seed": "@php bin/spora db:seed",
        "test": "./vendor/bin/pest",
        "test:coverage": "./vendor/bin/pest --coverage --coverage-html=coverage",
        "analyse": "./vendor/bin/phpstan analyse --memory-limit=2G",
        "format": "./vendor/bin/php-cs-fixer fix",
        "frontend:dev": [
            "Composer\\Config::disableProcessTimeout",
            "cd frontend && npm run dev"
        ],
        "frontend:build": [
            "Composer\\Config::disableProcessTimeout",
            "cd frontend && npm run build"
        ],
        "frontend:test": "cd frontend && npm test",
        "frontend:preview": "cd frontend && npm run preview"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
