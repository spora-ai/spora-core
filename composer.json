{
    "name": "spora/spora",
    "description": "The WordPress of AI Agents — a portable, zero-configuration agent orchestration platform.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "symfony/http-foundation": "^7.2",
        "symfony/messenger": "^7.2",
        "nikic/fast-route": "^1.3",
        "php-di/php-di": "^7.1",
        "illuminate/database": "^13.0",
        "delight-im/auth": "^9.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.94",
        "pestphp/pest": "^3.8"
    },
    "autoload": {
        "psr-4": {
            "Spora\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "./vendor/bin/pest"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
