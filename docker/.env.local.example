# Tell Frankenphp, to only bind on localhost:80, don't generate SSL Certs
# Set to yopur domain in production
SERVER_NAME=localhost:80

# Spora Docker environment configuration — copy to .env.local for overrides
# .env.local takes priority over .env and config.php

# ── Application ────────────────────────────────────────────────────────────────

SPORA_APP_ENV=development
SPORA_ALLOW_REGISTRATION=true

# ── Encryption ─────────────────────────────────────────────────────────────────

# Base64-encoded 32-byte secret key used to encrypt tool credentials at rest.
# Generate with: php -r "echo base64_encode(random_bytes(32));"
# SPORA_SECRET_KEY=your-base64-key-here

# ── Database ───────────────────────────────────────────────────────────────────

SPORA_DB_DRIVER=mysql
SPORA_DB_HOST=mariadb
SPORA_DB_PORT=3306
SPORA_DB_NAME=spora
SPORA_DB_USER=spora
SPORA_DB_PASSWORD=spora

# ── Worker ──────────────────────────────────────────────────────────────────────

# true  — HTTP request blocks until agent completes (dev only)
# false — Task starts as QUEUED and is drained by worker:run (production)
SPORA_SYNC_MODE=false

# Minutes after which a RUNNING task is considered orphaned (0 = disabled).
SPORA_WORKER_STALE_MINUTES=60

# Maximum concurrent workers (0 = unlimited)
SPORA_MAX_WORKERS=0

# ── Timeouts ───────────────────────────────────────────────────────────────────

# LLM provider request timeout (seconds)
SPORA_LLM_TIMEOUT=300

# HTTP timeout for tool web requests (seconds)
SPORA_TOOL_HTTP_TIMEOUT=30

# ── Mercure (Real-time SSE via FrankenPHP native) ──────────────────────────────

# FrankenPHP bundles Mercure natively — no separate service needed.
# Omit entirely to disable SSE (UI won't auto-refresh, tasks still work).
# For local Docker: http://host.docker.internal:80/.well-known/mercure
# Or simply: http://localhost/.well-known/mercure
SPORA_MERCURE_URL=http://localhost:8080/.well-known/mercure

# Optional: separate URL the server uses to publish updates (defaults to SPORA_MERCURE_URL).
# Use this when the publish endpoint differs from the subscribe URL (e.g., Docker internal network).
# SPORA_MERCURE_PUBLISH_URL=http://host.docker.internal:80/.well-known/mercure

# HS256 shared secret for Mercure JWT signing.
# Generate with: php -r "echo bin2hex(random_bytes(32));"
# Must match the publisher_jwt in frankenphp.conf
SPORA_MERCURE_JWT_KEY=change-me-use-a-long-random-secret-key

# ── Logging ─────────────────────────────────────────────────────────────────────

# debug | info | warning | error
# WARNING is the default. Use debug locally to see all tool dispatch events.
# Do NOT use debug in production — tool arguments (potentially PII) are logged.
SPORA_LOG_LEVEL=debug

# Log file path. Defaults to storage/spora.log.
# SPORA_LOG_PATH=/var/log/spora.log

# ── Mail ───────────────────────────────────────────────────────────────────────

# SMTP mail configuration (symfony/mailer)
# SMTP credentials are encrypted at rest and stored in the database when set via UI.
# Use these env vars for Docker/CI environments where no UI is available.
#
# SMTP example (Gmail / compatible):
# SPORA_MAIL_DRIVER=smtp
# SPORA_MAIL_HOST=smtp.gmail.com
# SPORA_MAIL_PORT=587
# SPORA_MAIL_USERNAME=your-email@gmail.com
# SPORA_MAIL_PASSWORD=your-app-password
# SPORA_MAIL_ENCRYPTION=tls
# SPORA_MAIL_FROM=your-email@gmail.com
# SPORA_MAIL_FROM_NAME=Spora

# PHP mail() function (default, no config needed):
# SPORA_MAIL_DRIVER=php_mail

# Log only (dev — writes email metadata to spora.log instead of sending):
SPORA_MAIL_DRIVER=log
