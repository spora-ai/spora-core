#!/usr/bin/env bash
#
# Start the full local development stack:
#   - PHP built-in server on localhost:8080
#   - Vite dev server on localhost:5173 (proxies /api to PHP)
#
# Usage: bin/dev   or   composer dev

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BASE_DIR="$(dirname "$SCRIPT_DIR")"
PHP_LOG="$BASE_DIR/storage/php.log"
PHP_PORT="${PHP_PORT:-8080}"

mkdir -p "$BASE_DIR/storage"

echo "Starting PHP server on http://localhost:${PHP_PORT} (log: storage/php.log)"
php -S "localhost:${PHP_PORT}" -t "$BASE_DIR/public" > "$PHP_LOG" 2>&1 &
PHP_PID=$!

cleanup() {
    kill "$PHP_PID" 2>/dev/null || true
}
trap cleanup EXIT INT TERM

echo "Starting Vite dev server on http://localhost:5173"
npm --prefix "$BASE_DIR/frontend" run dev

