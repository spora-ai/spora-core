#!/usr/bin/env php
<?php

declare(strict_types=1);

require_once __DIR__ . '/../vendor/autoload.php';

use Symfony\Component\Console\Application;
use Symfony\Component\Console\Attribute\AsCommand;
use Symfony\Component\Console\Command\Command;
use Symfony\Component\Console\Input\InputArgument;
use Symfony\Component\Console\Input\InputInterface;
use Symfony\Component\Console\Output\OutputInterface;
use Symfony\Component\Console\Style\SymfonyStyle;

/**
 * Build-time companion to `bin/spora`. Same shape (Symfony Console entry, multiple
 * subcommands), but deliberately skips the `Kernel` / DI / `storage/secret.key` boot —
 * every command here must work in a clean checkout with only the source tree.
 *
 * Today only the OpenAPI generator ships; future build-time tools (recipe lint,
 * migration dry-run, etc.) are expected to land here too. To add a new subcommand,
 * write an `#[AsCommand]` class below and register it in `$app->add(...)`.
 */

#[AsCommand(
    name: 'openapi:generate',
    description: 'Generate the OpenAPI 3.0 spec (openapi.json) from RouteDefinitions.',
)]
final class OpenApiGenerateCommand extends Command
{
    protected function configure(): void
    {
        $this->addArgument(
            'output',
            InputArgument::OPTIONAL,
            'Where to write the JSON document (relative to BASE_PATH or absolute).',
            'openapi.json',
        );
    }

    protected function execute(InputInterface $input, OutputInterface $output): int
    {
        $io = new SymfonyStyle($input, $output);
        $path = (string) $input->getArgument('output');
        if ($path !== '' && $path[0] !== '/') {
            $base = defined('BASE_PATH') ? BASE_PATH : dirname(__DIR__, 2);
            $path = rtrim($base, '/') . '/' . ltrim($path, '/');
        }
        $wrote = \Spora\Console\Commands\OpenApiGenerateCommand::regenerate($path);
        if ($wrote === Command::SUCCESS) {
            $io->success('Done.');
        } else {
            $io->error('Failed — see error above.');
        }
        return $wrote;
    }
}

#[AsCommand(
    name: 'openapi:check',
    description: 'Exit non-zero if the committed spec differs from a fresh regeneration.',
)]
final class OpenApiCheckCommand extends Command
{
    protected function configure(): void
    {
        $this->addArgument(
            'committed',
            InputArgument::OPTIONAL,
            'Path to the committed spec to compare against.',
            'openapi.json',
        );
    }

    protected function execute(InputInterface $input, OutputInterface $output): int
    {
        $io = new SymfonyStyle($input, $output);
        $result = \Spora\Console\Commands\OpenApiGenerateCommand::checkAgainstFile((string) $input->getArgument('committed'));
        if ($result === Command::SUCCESS) {
            $io->success('Done.');
        } else {
            $io->error('Done (with drift — see error above).');
        }
        return $result;
    }
}

$app = new Application('Spora Build', \Spora\Core\Version::current());
$app->addCommand(new OpenApiGenerateCommand());
$app->addCommand(new OpenApiCheckCommand());
$app->run();
