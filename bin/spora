#!/usr/bin/env php
<?php

declare(strict_types=1);

// BASE_PATH is defined by the consumer's bin/spora stub (or by the
// dev-mode test bootstrap). If we're being invoked directly (e.g. as
// `vendor/bin/spora`), define it from the known depth of this script
// in vendor/. vendor/spora-ai/spora-core/bin/spora → up 3 = consumer root.
if (!defined('BASE_PATH')) {
    define('BASE_PATH', dirname(__FILE__, 3));
}

require_once BASE_PATH . '/vendor/autoload.php';

use Spora\Core\Kernel;
use Symfony\Component\Console\Application;
use Spora\Console\Commands\SetupCommand;
use Spora\Console\Commands\InstallCommand;
use Spora\Console\Commands\DbResetCommand;
use Spora\Console\Commands\SeedCommand;
use Spora\Console\Commands\PluginInstallCommand;
use Spora\Console\Commands\PluginListCommand;
use Spora\Console\Commands\PluginUninstallCommand;
use Spora\Console\Commands\PluginUpdateCommand;
use Spora\Console\Commands\TaskRunCommand;
use Spora\Console\Commands\ToolSettingsMigrationCommand;
use Spora\Console\Commands\WorkerRunCommand;

// 1. Boot Kernel to get the DI container. Each command boots its own DB connection.
try {
    $kernel = new Kernel();
    $container = $kernel->getContainer();
} catch (\Throwable $e) {
    echo sprintf("[Fatal] Failed to boot Spora kernel: %s\n", $e->getMessage());
    exit(1);
}

$application = new Application('Spora CLI', \Spora\Core\Version::current());

// Register Commands Manually or Autowire them from container
$application->addCommand($container->get(SetupCommand::class));
$application->addCommand($container->get(InstallCommand::class));
$application->addCommand($container->get(DbResetCommand::class));
$application->addCommand($container->get(SeedCommand::class));
$application->addCommand($container->get(PluginInstallCommand::class));
$application->addCommand($container->get(PluginListCommand::class));
$application->addCommand($container->get(PluginUninstallCommand::class));
$application->addCommand($container->get(PluginUpdateCommand::class));
$application->addCommand($container->get(TaskRunCommand::class));
$application->addCommand($container->get(ToolSettingsMigrationCommand::class));
$application->addCommand($container->get(WorkerRunCommand::class));

$application->run();