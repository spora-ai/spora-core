meta {
  name: Update Agent
  type: http
  seq: 2
}

patch {
  url: {{baseUrl}}/agent
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  X-XSRF-TOKEN: {{xsrfToken}}
}

body:json {
  {
    "name": "My Assistant",
    "description": "A general-purpose assistant.",
    "recipe_id": "general_assistant",
    "llm_provider": "openai_compatible",
    "llm_model": "gpt-4o",
    "llm_base_url": null,
    "max_steps": 15,
    "is_active": true
  }
}
