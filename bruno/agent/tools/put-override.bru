meta {
  name: Save Agent Tool Override
  type: http
  seq: 5
}

put {
  url: {{baseUrl}}/agent/tools/Spora%5CTools%5CBuiltin%5CSearchWebTool/override
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  X-XSRF-TOKEN: {{xsrfToken}}
}

body:json {
  {
    "settings": {
      "api_key": "sk-my-personal-serpapi-key"
    }
  }
}
