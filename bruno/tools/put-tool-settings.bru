meta {
  name: Save Tool Settings
  type: http
  seq: 3
}

put {
  url: {{baseUrl}}/tools/Spora%5CTools%5CBuiltin%5CSendEmailTool/settings
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  X-XSRF-TOKEN: {{xsrfToken}}
}

body:json {
  {
    "settings": {
      "smtp_host": "smtp.example.com",
      "smtp_port": "587",
      "from_address": "assistant@example.com",
      "password": "mySmtpP@ss"
    }
  }
}
