{
  "$schema": "https://spora.dev/agent-template.schema.json",
  "id": "core/core-assistant",
  "name": "Spora Core Agent",
  "description": "Default Spora agent with time and math tools.",
  "version": "1.0.0",
  "agent": {
    "description": "Spora's general-purpose starter agent.",
    "system_prompt": "You are a helpful AI assistant. Use the tools available to you when appropriate, and explain your reasoning before taking action.",
    "max_steps": 10,
    "allow_continuation": true,
    "retry_after_minutes": 0,
    "max_retries": 0
  },
  "tools": [
    {
      "tool_class": "Spora\\Tools\\CurrentTimeTool",
      "enabled": true,
      "operations": [
        { "name": "now", "enabled": true, "auto_approve": true }
      ]
    },
    {
      "tool_class": "Spora\\Tools\\CalculatorTool",
      "enabled": true,
      "operations": [
        { "name": "calculate", "enabled": true, "auto_approve": true }
      ]
    }
  ],
  "required_plugins": [],
  "metadata": {
    "category": "general",
    "icon": "puzzle"
  }
}